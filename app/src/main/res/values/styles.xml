<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Header 1 Style -->
    <style name="H1" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/headline_copy_gray</item>
    </style>

    <!-- Header 1 Style: v1 -->
    <style name="H1.v1" parent="@style/H1">
        <item name="android:textColor">@color/dark_purple</item>
    </style>

    <!-- Header 1 Style: v2 -->
    <style name="H1.v2" parent="@style/H1">
        <item name="android:textColor">@color/teal</item>
    </style>

    <!-- Header 2 Style -->
    <style name="H2" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/headline_copy_gray</item>
    </style>

    <!-- Body 2 Style -->
    <style name="B2" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/body_copy_gray</item>
    </style>

    <!-- Body 2 Style: v1 -->
    <style name="B2.v1" parent="@style/B2" >
        <item name="android:fontFamily">@font/roboto_medium</item>
        <item name="android:textColor">@color/dark_purple</item>
    </style>

    <!-- Body 3 Style -->
    <style name="B3" >
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/roboto_medium</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/dark_purple</item>
    </style>

    <!-- Quote Style -->
    <style name="Q1" >
        <item name="android:layout_gravity">center</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">15dp</item>
        <item name="android:layout_marginEnd">15dp</item>
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Icon Style -->
    <style name="I1" >
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:adjustViewBounds">true</item>
        <item name="android:maxHeight">60dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:clickable">true</item>
    </style>

</resources>